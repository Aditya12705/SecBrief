# ArmorIQ — https://platform.armoriq.ai
ARMORIQ_API_KEY=ak_live_your_key_here
# Optional: policy from Visual Policy Builder
# ARMORIQ_POLICY_ID=

# Mistral API — https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_MODEL=mistral-small-latest

# GitHub (optional — higher API rate limits for repo scan)
# GITHUB_TOKEN=ghp_your_token_here

# Fail closed when ArmorIQ is configured but verification errors (recommended for demos)
# SECBRIEF_STRICT_ARMORIQ=true

# Backend URL (frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
SECBRIEF_STRICT_ARMORIQ=true
# GITHUB_TOKEN=github_pat_your_token_here
