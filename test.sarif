{
  "$schema": "https://schemastore.azurewebsites.net/schemas/sarif/sarif-2.1.0-rtm.5.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ESLint",
          "rules": [
            {
              "id": "no-unused-vars",
              "shortDescription": {
                "text": "Variables that are declared but not used."
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "no-unused-vars",
          "message": {
            "text": "'x' is assigned a value but never used."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "file:///C:/Users/user/project/index.js"
                },
                "region": {
                  "startLine": 1,
                  "startColumn": 7
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
